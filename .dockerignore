# Dependencies
node_modules
**/node_modules

# Build outputs
.next
**/.next
dist
**/dist
.turbo
**/.turbo

# Version control
.git
.gitignore

# Environment files (never bake secrets into images)
.env
.env.*
!.env.*.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS metadata
.DS_Store
Thumbs.db

# Editor configs
.vscode
.idea
*.swp
*.swo

# Test artifacts
coverage
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Docker files (avoid recursive context)
Dockerfile*
docker-compose*.yml
nginx/
